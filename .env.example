# RAYO — variáveis de ambiente de exemplo. Copie para `.env` (ou defina como
# Secrets no Replit) preenchendo os valores reais. NUNCA commitar `.env`.

# --- Núcleo ---
DATABASE_URL=postgres://user:pass@host:5432/rayo
NODE_ENV=development

# Domínio canônico da app em produção (usado por sitemap/robots/etc).
PUBLIC_SITE_URL=https://rayo.app.br
APP_BASE_URL=https://rayo.app.br

# --- Email (Resend) ---
resend_api_key=
RESEND_FROM_EMAIL=RAYO <onboarding@resend.dev>
APP_URL=https://rayo.app.br

# --- Admin bootstrap ---
ADMIN_EMAILS=

# --- CORS ---
# Lista separada por vírgula. `https://rayo.app.br` é sempre incluído em
# produção, mesmo que esta variável esteja vazia.
ALLOWED_ORIGINS=

# --- OAuth Google (Task #69) ---
# IMPORTANTE: o Google OAuth está travado no domínio de produção. A redirect
# URI abaixo é a ÚNICA aceita pelo backend; ela precisa estar registrada
# *exatamente* no Google Cloud Console como "Authorized redirect URI".
# Em dev/preview o botão "Entrar com Google" não funciona — use email/senha.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://rayo.app.br/api/auth/google/callback

# --- OAuth Facebook (Task #72) ---
# Mesmo padrão do Google: callback travada no domínio canônico de produção.
# Em dev/preview o botão "Entrar com Facebook" fica como "Em breve".
# Cadastrar a redirect URI abaixo em developers.facebook.com → seu app →
# Facebook Login → Settings → "Valid OAuth Redirect URIs".
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=https://rayo.app.br/api/auth/facebook/callback

# --- Bunny Stream (vídeo) ---
# Ver docs/contracts/bunny-stream.md. Sem estas vars, upload/embed de vídeo
# Bunny ficam indisponíveis (sentinels bunny:// não resolvem).
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_CDN_HOSTNAME=
BUNNY_STREAM_WEBHOOK_SECRET=

# --- Stripe (Trilhas pagas) ---
# Em produção no Replit as credenciais vêm do Replit Connector (não de env).
# STRIPE_WEBHOOK_SECRET é gerenciado pelo stripe-replit-sync (opcional).
STRIPE_WEBHOOK_SECRET=

# --- Realtime (Socket.IO) ---
SOCKET_IO_ENABLED=true
SOCKET_IO_PATH=/socket.io

# --- Web Push (notificações no celular) ---
# Gere com: npx web-push generate-vapid-keys
# Sem as chaves, o push fica desligado (o app funciona normalmente).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@rayo.app.br

# --- Contatos institucionais / segurança ---
CONTACT_EMAIL=
SECURITY_CONTACT_EMAIL=
DPO_CONTACT_EMAIL=
SECURITY_POLICY_URL=

# --- Integrações internas ---
# Chave exigida pelos endpoints internos de gamification (403 se ausente).
INTERNAL_API_KEY=

# --- Object Storage (Replit) ---
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=

# --- Diversos ---
LOG_LEVEL=info
# Dias de trial das trilhas pagas (default 7).
TRAIL_TRIAL_DAYS=7
# Habilita o protótipo do Conselheiro IA (chat simulado) — manter false em
# produção até existir backend real.
VITE_CONSELHEIRO_ENABLED=false
