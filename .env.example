# RAYO — variáveis de ambiente de exemplo. Copie para `.env` (ou defina como
# Secrets no Replit) preenchendo os valores reais. NUNCA commitar `.env`.

# --- Núcleo ---
DATABASE_URL=postgres://user:pass@host:5432/rayo
NODE_ENV=development

# Domínio canônico da app em produção (usado por sitemap/robots/etc).
PUBLIC_SITE_URL=https://rayo.app.br
APP_BASE_URL=https://rayo.app.br

# --- Email (Resend) ---
resend_api_key=
RESEND_FROM_EMAIL=RAYO <onboarding@resend.dev>
APP_URL=https://rayo.app.br

# --- Admin bootstrap ---
ADMIN_EMAILS=

# --- CORS ---
# Lista separada por vírgula. `https://rayo.app.br` é sempre incluído em
# produção, mesmo que esta variável esteja vazia.
ALLOWED_ORIGINS=

# --- OAuth Google (Task #69) ---
# IMPORTANTE: o Google OAuth está travado no domínio de produção. A redirect
# URI abaixo é a ÚNICA aceita pelo backend; ela precisa estar registrada
# *exatamente* no Google Cloud Console como "Authorized redirect URI".
# Em dev/preview o botão "Entrar com Google" não funciona — use email/senha.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://rayo.app.br/api/auth/google/callback

# --- OAuth Apple (opcional) ---
# APPLE_REDIRECT_URI é OPCIONAL — se ausente, o backend monta a callback
# a partir de APP_URL/REPLIT_DEV_DOMAIN (comportamento legado preservado).
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=
